#!/bin/sh
# netlock daemon: open the internet only while a "key" phone is present
# on the WiFi, cut it (for all LAN clients) once the phone has been gone longer
# than the grace period. Works with OpenClash TProxy because blocking happens at
# the raw/prerouting stage (priority -300), before the TProxy redirect.

. /lib/functions.sh
. /lib/functions/network.sh

CONF=netlock
STATUS_FILE=/var/run/netlock.json
LOG_TAG=netlock
MAC_RE='([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}'

log() { logger -t "$LOG_TAG" "$1"; }

# ---------------------------------------------------------------------------
# config (re-read every loop so a service reload picks up changes)
# ---------------------------------------------------------------------------
load_config() {
	enabled=$(uci -q get "$CONF.global.enabled" || echo 0)
	grace_period=$(uci -q get "$CONF.global.grace_period" || echo 300)
	poll_interval=$(uci -q get "$CONF.global.poll_interval" || echo 10)
	target_macs=$(uci -q get "$CONF.global.target_mac" | tr 'A-F' 'a-f')
	monitor_ifaces=$(uci -q get "$CONF.global.monitor_iface")

	[ "$poll_interval" -ge 2 ] 2>/dev/null || poll_interval=10
	[ "$grace_period" -ge 0 ] 2>/dev/null || grace_period=300
}

# ---------------------------------------------------------------------------
# presence detection
# ---------------------------------------------------------------------------
list_ap_ifaces() {
	if [ -n "$monitor_ifaces" ]; then
		echo "$monitor_ifaces"
	else
		ubus list 2>/dev/null | sed -n 's/^hostapd\.//p'
	fi
}

# MACs currently associated to an AP that THIS router runs (empty when the
# router has no WiFi and the phone joins a downstream/bridged AP instead).
get_associated_macs() {
	for ifc in $(list_ap_ifaces); do
		iwinfo "$ifc" assoclist 2>/dev/null | grep -oE "$MAC_RE"
		ubus -S call "hostapd.$ifc" get_clients 2>/dev/null | grep -oE "$MAC_RE"
	done | tr 'A-F' 'a-f' | sort -u
}

lease_ip() {
	awk -v m="$1" 'tolower($2)==m {print $3; exit}' /tmp/dhcp.leases 2>/dev/null
}

# IP for a MAC: prefer the live neighbor table, fall back to the DHCP lease.
target_ip() {
	local ip
	ip=$(ip neigh show 2>/dev/null | awk -v m="$1" 'tolower($0) ~ m {print $1; exit}')
	[ -n "$ip" ] || ip=$(lease_ip "$1")
	echo "$ip"
}

# Phone confirmed reachable on the LAN by the neighbor table.
# Only REACHABLE/DELAY/PROBE count — STALE means "was here but unverified"
# and must fall through to the ping step below.
neigh_reachable() {
	ip neigh show 2>/dev/null | awk -v m="$1" '
		tolower($0) ~ m && /REACHABLE|DELAY|PROBE/ { found=1 }
		END { exit !found }'
}

# Sets MATCHED to the list of target MACs found present. Returns 0 if any
# target phone is present, 1 otherwise. Detection is topology-independent:
# 1) associated to our own AP, 2) reachable LAN neighbor, 3) ping reply.
phone_present() {
	MATCHED=""
	local assoc t ip present=0
	assoc=$(get_associated_macs)

	for t in $target_macs; do
		if echo "$assoc" | grep -qx "$t"; then
			MATCHED="$MATCHED $t"; present=1; continue
		fi
		if neigh_reachable "$t"; then
			MATCHED="$MATCHED $t"; present=1; continue
		fi
		# ping wakes/confirms a phone that briefly went idle
		ip=$(target_ip "$t")
		if [ -n "$ip" ] && ping -c1 -W1 "$ip" >/dev/null 2>&1; then
			MATCHED="$MATCHED $t"; present=1; continue
		fi
	done

	[ "$present" = 1 ]
}

# ---------------------------------------------------------------------------
# firewall toggle — own nft table, independent of fw4
# Hooks at prerouting priority -300 (raw stage), before fw4 and OpenClash
# TProxy, so both direct and proxied traffic are cut simultaneously.
# ---------------------------------------------------------------------------
lan_info() {
	network_flush_cache
	network_get_device LAN_DEV lan || LAN_DEV=br-lan
	network_get_subnet LAN_SUBNET lan || LAN_SUBNET="$(uci -q get network.lan.ipaddr)/24"
	network_get_subnet6 LAN_SUBNET6 lan
	ULA=$(uci -q get network.globals.ula_prefix)
}

nft_block() {
	lan_info
	local v6_local="fe80::/10, ff00::/8"
	[ -n "$LAN_SUBNET6" ] && v6_local="$v6_local, $LAN_SUBNET6"
	[ -n "$ULA" ] && v6_local="$v6_local, $ULA"

	nft -f - <<-EOF
		table inet netlock {
			chain prerouting {
				type filter hook prerouting priority -300; policy accept;
				iifname "$LAN_DEV" ip  daddr $LAN_SUBNET accept
				iifname "$LAN_DEV" ip  daddr { 224.0.0.0/4, 255.255.255.255 } accept
				iifname "$LAN_DEV" meta nfproto ipv4 counter drop
				iifname "$LAN_DEV" ip6 daddr { $v6_local } accept
				iifname "$LAN_DEV" meta nfproto ipv6 counter drop
			}
		}
	EOF
}

nft_unblock() {
	nft delete table inet netlock 2>/dev/null
	return 0
}

# ---------------------------------------------------------------------------
# status file for the LuCI page
# ---------------------------------------------------------------------------
json_arr() {
	local first=1 out="[" x
	for x in $1; do
		[ "$first" = 1 ] || out="$out,"
		out="$out\"$x\""
		first=0
	done
	echo "$out]"
}

write_status() {
	# $1 present(0/1) $2 blocked(0/1) $3 last_seen(epoch)
	cat > "$STATUS_FILE" <<-EOF
		{"enabled":$enabled,"present":$1,"blocked":$2,"last_seen":$3,"grace_period":$grace_period,"poll_interval":$poll_interval,"targets":$(json_arr "$target_macs"),"matched":$(json_arr "$MATCHED")}
	EOF
}

# ---------------------------------------------------------------------------
# main loop
# ---------------------------------------------------------------------------
cleanup() {
	nft_unblock
	log "stopped, internet left open"
	exit 0
}
trap cleanup TERM INT

main() {
	local now last_seen=0 blocked=-1
	MATCHED=""

	load_config
	# fail-safe initial state: block until a phone is confirmed present
	if [ "$enabled" = 1 ] && [ -n "$target_macs" ]; then
		nft_block; blocked=1
	else
		nft_unblock; blocked=0
	fi

	while :; do
		load_config
		now=$(date +%s)

		if [ "$enabled" != 1 ]; then
			[ "$blocked" = 0 ] || { nft_unblock; blocked=0; log "disabled, internet open"; }
			MATCHED=""; write_status 0 0 "$last_seen"
			sleep "$poll_interval"; continue
		fi

		if [ -z "$target_macs" ]; then
			[ "$blocked" = 0 ] || { nft_unblock; blocked=0; }
			log "no target_mac configured, internet open"
			MATCHED=""; write_status 0 0 "$last_seen"
			sleep "$poll_interval"; continue
		fi

		if phone_present; then
			last_seen=$now
			[ "$blocked" = 0 ] || { nft_unblock; blocked=0; log "anchor present -> internet ON (${MATCHED# })"; }
			write_status 1 0 "$last_seen"
		elif [ $((now - last_seen)) -ge "$grace_period" ]; then
			[ "$blocked" = 1 ] || { nft_block; blocked=1; log "anchor absent > ${grace_period}s -> internet OFF"; }
			write_status 0 1 "$last_seen"
		else
			# inside grace window: hold the current state
			write_status 0 "$blocked" "$last_seen"
		fi

		sleep "$poll_interval"
	done
}

main
